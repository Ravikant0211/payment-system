# Application
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# PostgreSQL
DATABASE_URL=postgresql://payment:payment@localhost:5432/payment_db
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_SSL=false

# Redis
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=payment:
IDEMPOTENCY_KEY_TTL_SECONDS=86400

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=payment-system
KAFKA_GROUP_ID_PREFIX=payment-system
KAFKA_SSL=false
# KAFKA_SASL_MECHANISM=plain
# KAFKA_SASL_USERNAME=user
# KAFKA_SASL_PASSWORD=password

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_API_VERSION=2023-10-16

# Security
API_KEY_SALT=change-me-to-a-random-32-char-string

# Scheduler
RECONCILIATION_CRON=0 2 * * *
OUTBOX_POLL_INTERVAL_MS=500
OUTBOX_MAX_BATCH_SIZE=100
OUTBOX_MAX_RETRIES=5

# Alerting (optional - Slack webhook for critical alerts)
ALERT_SLACK_WEBHOOK_URL=
ALERT_EMAIL_TO=
